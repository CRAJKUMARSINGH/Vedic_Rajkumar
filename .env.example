# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# ── Analytics (Week 27) ───────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable Swiss Ephemeris WASM (Phase 4 — Week 28+)
VITE_USE_SWISS_EPHEMERIS=false

# Enable Web Worker for calculations (Phase 5)
VITE_USE_CALC_WORKER=true

# ── App Config ────────────────────────────────────────────────────────────────
VITE_APP_NAME="Vedic Rajkumar"
VITE_APP_URL=https://your-domain.vercel.app

# ── Vercel (set in Vercel dashboard, not committed) ───────────────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
